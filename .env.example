# Polygon API key (Stocks Starter plan, $29/mo)
# Primary stocks data provider as of DESIGN.md v3.
# Required for Test 1 in scripts/verify_data.py.
POLYGON_API_KEY=your_polygon_api_key_here

# Tradier API tokens
# Retained for brokerage integration (paper/live trading) and recent-window cross-checks.
# NOT used for historical backtest data after v3 — see docs/data-provider-notes.md.
TRADIER_PRODUCTION_API_TOKEN=your_production_token_here

# Sandbox token: lower rate limits, limited historical coverage
TRADIER_API_TOKEN=your_sandbox_token_here

# Anthropic API — Phase 3 generator pipeline
# Required to run scripts/discover.py.
# Default model is claude-sonnet-4-6; override via ANTHROPIC_MODEL.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
# Monthly spend cap in USD; new generations refuse if projected spend would exceed it.
ANTHROPIC_MONTHLY_CAP_USD=100
